# ===================================================
# IGLESIA DE CRISTO EBENEZER - FestiKids
# Variables de Entorno
# ===================================================
# Copia este archivo como .env y completa los valores

# ----- WHATSAPP -----
# Número de contacto principal (formato internacional sin +)
WHATSAPP_NUMBER=584128580894
# Mensaje predefinido para el botón de donación
WHATSAPP_MESSAGE=quiero formar parte de festikids

# ----- BASE DE DATOS -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=festikids_db
DB_USER=postgres
DB_PASSWORD=tu_password_seguro

# ----- SITIO WEB -----
SITE_URL=https://www.festikids.org
SITE_NAME=Iglesia de Cristo Ebenezer - FestiKids
SITE_DESCRIPTION=Iglesia que brinda alimentos, atención médica, cortes de cabello y medicina a niños. Apoya nuestro FestiKids.

# ----- FUTURO: PAGOS (cuando se integren) -----
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ----- FUTURO: PAGO MÓVIL VENEZUELA (C2P) -----
# BANK_API_URL=https://api.banco.com/v1
# BANK_API_KEY=...
# MERCHANT_ID=...
# MERCHANT_PHONE=...
# MERCHANT_CEDULA=...
# MERCHANT_BANK_CODE=...

# ----- GOOGLE (opcional) -----
